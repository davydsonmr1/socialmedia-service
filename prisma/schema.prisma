// =====================================================
// LinkedBridge — Prisma Schema
// =====================================================
// Security Notes:
// - OAuthCredential is isolated from User to reduce
//   blast radius in case of a data breach.
// - AES-256-GCM fields (iv, authTag) stored alongside
//   the ciphertext for proper decryption.
// - PortfolioApiKey stores only the hash of the key,
//   never the plaintext value.
// =====================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ----- Core User Model -----
model User {
  id        String   @id @default(uuid()) @db.Uuid
  email     String   @unique @db.VarChar(320)
  name      String   @db.VarChar(255)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Relations
  oauthCredential OAuthCredential?
  portfolioApiKeys PortfolioApiKey[]
  postCaches       PostCache[]

  @@map("users")
}

// ----- OAuth Credentials (Isolated — Blast Radius Reduction) -----
// This table is intentionally separated from User so that a breach
// of the main users table does NOT expose encrypted tokens.
// AES-256-GCM requires: ciphertext + iv + authTag for decryption.
model OAuthCredential {
  id                   String    @id @default(uuid()) @db.Uuid
  userId               String    @unique @map("user_id") @db.Uuid
  providerName         String    @default("linkedin") @map("provider_name") @db.VarChar(50)
  encryptedAccessToken String    @map("encrypted_access_token") @db.Text
  iv                   String    @db.VarChar(32)
  authTag              String    @map("auth_tag") @db.VarChar(32)
  linkedInSub          String?   @map("linkedin_sub") @db.VarChar(100)
  refreshToken         String?   @map("refresh_token") @db.Text
  expiresAt            DateTime? @map("expires_at")
  createdAt            DateTime  @default(now()) @map("created_at")
  updatedAt            DateTime  @updatedAt @map("updated_at")

  // Relations
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("oauth_credentials")
}

// ----- Portfolio API Keys (Hashed — Never Plaintext) -----
// The raw key is shown to the user ONCE at creation time.
// We store only the SHA-256 hash for constant-time comparison.
model PortfolioApiKey {
  id        String    @id @default(uuid()) @db.Uuid
  userId    String    @map("user_id") @db.Uuid
  hashedKey String    @unique @map("hashed_key") @db.VarChar(128)
  keyHint   String    @map("key_hint") @db.VarChar(12)
  revokedAt DateTime? @map("revoked_at")
  createdAt DateTime  @default(now()) @map("created_at")

  // Relations
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([hashedKey])
  @@map("portfolio_api_keys")
}

// ----- Post Cache (1-Hour TTL Managed by Worker) -----
model PostCache {
  id             String   @id @default(uuid()) @db.Uuid
  userId         String   @map("user_id") @db.Uuid
  externalPostId String   @map("external_post_id") @db.VarChar(255)
  content        Json
  imageUrl       String?  @map("image_url") @db.Text
  postedAt       DateTime @map("posted_at")
  cachedAt       DateTime @default(now()) @map("cached_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  // Relations
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, externalPostId])
  @@index([userId])
  @@map("post_caches")
}
