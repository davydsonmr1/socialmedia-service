# ===================================================
# LinkedBridge — Environment Variables
# ===================================================
# Copy this file to .env and fill in the values.
# NEVER commit the .env file to version control.
# ===================================================

# ---------------------------------------------------
# Database (Supabase / PostgreSQL)
# ---------------------------------------------------
DATABASE_URL="postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=public"

# ---------------------------------------------------
# Encryption (AES-256-GCM)
# ---------------------------------------------------
# MUST be exactly 32 bytes (256 bits) — the application will refuse to start otherwise (Fail-Fast).
#
# Generate with one of:
#   openssl rand -base64 32
#   node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
#
# The value MUST be a valid Base64 string that decodes to exactly 32 bytes.
ENCRYPTION_MASTER_KEY="your-base64-encoded-32-byte-key-here"

# ---------------------------------------------------
# Application
# ---------------------------------------------------
NODE_ENV="development"
PORT=3333

# ---------------------------------------------------
# LinkedIn OAuth 2.0
# ---------------------------------------------------
# Register your app at https://www.linkedin.com/developers/
# Required scopes: openid, profile, email, w_member_social
LINKEDIN_CLIENT_ID="your-linkedin-client-id"
LINKEDIN_CLIENT_SECRET="your-linkedin-client-secret"
LINKEDIN_REDIRECT_URI="http://localhost:3333/api/auth/linkedin/callback"

# ---------------------------------------------------
# Cron / Worker Authentication
# ---------------------------------------------------
# Secret key for authenticating internal cron webhook calls.
# Generate with: openssl rand -hex 32
# The worker endpoint rejects requests without this key.
CRON_SECRET_KEY="your-64-hex-char-cron-secret-here"
